{
  "name": "hipay-analyst",
  "version": "1.0.0",
  "description": "QA Analyst - Automatisation et analyse de l'API Order HiPay | BDD • CodeceptJS • Gherkin • TS",
  "main": "index.js",
  "scripts": {
    "test": "codeceptjs run --steps",
    "test:smoke": "codeceptjs run --grep @smoke --steps",
    "test:nominal": "codeceptjs run --grep @nominal --steps",
    "test:error": "codeceptjs run --grep @error --steps",
    "test:security": "codeceptjs run --grep @security --steps",
    "test:healthcheck": "codeceptjs run --grep @healthcheck --steps",
    "test:report": "codeceptjs run --steps --reporter mochawesome",
    "report:merge": "mochawesome-merge reports/*.json -o reports/test-report.json",
    "report:generate": "marge reports/test-report.json --reportDir reports --inline",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "chai": "^6.2.2",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@codeceptjs/allure-legacy": "^1.0.2",
    "@codeceptjs/configure": "^4.0.0-beta.4",
    "@cucumber/cucumber": "^13.0.0",
    "@types/chai": "^5.2.3",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "allure-commandline": "^2.43.0",
    "codeceptjs": "^4.0.9",
    "eslint": "^10.6.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}